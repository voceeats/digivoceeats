# ============================================================
# DigiVoceEats Environment Variables
# Copy this to .env.local and fill in your values
# ============================================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=DigiVoceEats
NEXT_PUBLIC_BRAND_COLOR=#FF6B35

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_key
STRIPE_SECRET_KEY=sk_live_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PLATFORM_ACCOUNT_ID=acct_your_platform_id

# Platform fee (Diginetplore cut)
PLATFORM_FEE_PERCENT=15

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+12025550100

# Amazon SNS (SMS fallback)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_SNS_ORIGINATION_NUMBER=

# Retell AI
RETELL_API_KEY=your_retell_api_key
RETELL_AGENT_ID=your_retell_agent_id
RETELL_WEBHOOK_SECRET=your_retell_webhook_secret

# Anthropic (Menu extraction)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Resend (Monthly report emails)
RESEND_API_KEY=
RESEND_FROM_EMAIL=reports@digivoceeats.com

# Vercel Cron (auto-generated secret in Vercel dashboard)
CRON_SECRET=

# Admin
NEXT_PUBLIC_ADMIN_EMAIL=admin@diginetplore.com

# Payment link expiry (minutes)
PAYMENT_LINK_EXPIRY_MINUTES=30
